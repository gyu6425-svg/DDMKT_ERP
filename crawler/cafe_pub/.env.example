# 카페 설정 — 이 파일을 .env 로 복사해 값 채우기. (SUPABASE_* 는 ../.env 재사용됨)

# ── 원고 '생성'만 하는 PC 도 쓰는 값 ──
# 배너 이미지 생성 API. 기본은 로컬 개발서버(npm run api:dev, 8787).
# 로컬 서버 안 띄우고 배포본을 쓰려면 운영 주소로 바꾸세요.
#   예) CAFE_BANNER_API=https://<배포도메인>/api/generate-cafe-card
# CAFE_BANNER_API=http://127.0.0.1:8787/api/generate-cafe-card

# ── 아래부터는 카페 '발행'까지 하는 PC 에서만 의미 있음 ──
# 카페 글쓰기 페이지 주소(스마트에디터). 예: https://cafe.naver.com/ca-fe/cafes/12345678/articles/write?boardType=L
CAFE_WRITE_URL=
# 완전 자동 발행하려면 0 (기본 1 = 수동보조: '등록' 직전까지만 채우고 멈춤)
CAFE_NO_SEND=1
# 발행 최소 간격(분) — 계정 안전. 너무 짧게 하지 마세요.
CAFE_MIN_GAP_MIN=30
# 이 시각(HH:MM) 이 지나면 그날은 더 발행하지 않음(세션 유지 핑만). 비우면 제한 없음.
# CAFE_STOP_AT=23:59
# 글 1건을 최소 몇 초에 걸쳐 작성할지(너무 빨리 쓰지 않게). 기본 330초.
# CAFE_MIN_SECONDS=330
# 유휴일 때 네이버 세션 유지 핑 간격(분). 기본 9분.
# CAFE_KEEPALIVE_MIN=9
# 첫 발행을 특정 시각(HH:MM)에 맞추고 싶을 때만. 평소엔 비워두세요.
# CAFE_FIRST_AT=18:13
# 게시판(메뉴) 이름. 기본 '누수'
# CAFE_BOARD=누수
