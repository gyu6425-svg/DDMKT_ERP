# 카페 댓글 자동화 설정 — 이 파일을 .env 로 복사해 값 채우기. (SUPABASE_* 는 ../.env 재사용됨)
# 완전 자동 등록하려면 0 (기본 1=수동보조: '등록' 직전까지만 입력)
CAFE_CMT_NO_SEND=1
# 댓글 최소 간격(분) — 계정 안전. ★계정별로 적용됨(멀티계정이면 계정마다 이 간격)
CAFE_CMT_MIN_GAP_MIN=20
# 새 글 감시 주기(분)
CAFE_CMT_WATCH_MIN=5
# 한 번 크롤에서 예약할 새 글 최대 건수(폭주 방지)
CAFE_CMT_WATCH_MAX=5
# 중복 판정 범위
#   account(기본) = 계정별로 글당 1개 (여러 계정이면 한 글에 계정 수만큼 달릴 수 있음)
#   global        = 계정 불문 글당 1개만
CAFE_CMT_DEDUP_SCOPE=account
# 세션 keep-alive 간격(분) — keep_alive.py 사용 시(워처가 돌면 보통 불필요)
CAFE_CMT_KEEPALIVE_MIN=40

# ── 멀티 계정 ──
# 계정 목록은 이 파일이 아니라 accounts.txt 에 있습니다(파이썬·bat 공용).
#   accounts.example.txt 를 accounts.txt 로 복사 → 계정마다 name,port,profile 한 줄
#   계정마다 1회 로그인:  run_chrome_login.bat <계정명>
