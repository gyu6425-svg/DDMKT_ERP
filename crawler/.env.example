# crawler/.env  (이 파일을 복사해 .env 로 저장하고 값 채우기 — .env 는 절대 깃에 올리지 마세요)
# 쓰는 곳: 블로그/플레이스/카페 순위 크롤러, 재검색 리스너, 카페 원고 생성기

# ── Supabase (필수) ──
# Supabase 대시보드 > Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
# ⚠️ service_role 키 (anon 아님). RLS를 우회해 기록하므로 외부 노출 절대 금지.
SUPABASE_SERVICE_KEY=your-service-role-key

# ── 네이버 검색 오픈 API (블로그탭 순위를 안정적으로 잡으려면 권장) ──
# https://developers.naver.com → 애플리케이션 등록 → 사용 API: '검색' 추가 → 발급
# 없으면 HTML 폴백으로 동작하지만 순위 정확도가 떨어질 수 있습니다.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── 카페 원고 생성기(cafe_pub/cafe_auto_publish.py) 를 쓸 때만 ──
# 레포 루트 .env 에 OPENAI_API_KEY 가 있으면 그게 쓰이므로 여기엔 없어도 됩니다.
# (.env 로드 순서: crawler/.env → crawler/cafe_pub/.env → 레포 루트 .env)
# OPENAI_API_KEY=sk-...
